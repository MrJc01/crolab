package report_test

import (
	"fmt"
	"os"
	"os/exec"
	"path/filepath"
	"strings"
	"testing"
	"time"
)

// Este teste atua como um gerador unificado de Documentação em Tempo Real.
// Ele sobe o Backend/Frontend temporariamente, e então atira uma instância
// Headless Chromium para fotografar cada tela em produção,
// compilando o result num Relatório Markdown final.

func TestGenerateReportFull(t *testing.T) {
	// 1. Setup Test Env & Directories
	reportDir := filepath.Join("..", "..", "documentacao", "relatorios")
	os.MkdirAll(reportDir, 0755)
	
	cliHome := filepath.Join(t.TempDir(), "cli_home")
	os.MkdirAll(cliHome, 0755)
	os.Setenv("CROLAB_HOME", cliHome)
	os.Setenv("HOME", cliHome)
	
	dbPath := filepath.Join(t.TempDir(), "crolab_test_report.db")

	// 2. Build the exact Crolab Binary
	t.Log("Building target binary...")
	binPath := filepath.Join(t.TempDir(), "crolab_bin")
	cmdBuild := exec.Command("go", "build", "-o", binPath, "../../cmd/crolab/")
	if err := cmdBuild.Run(); err != nil {
		t.Fatalf("falha no build: %v", err)
	}

	// 3. Start Crolab Provider (Frontend Admin/Client)
	t.Log("Starting Provider server for screenshots...")
	cmdServer := exec.Command(binPath, "provider", "--admin-port", ":18844", "--client-port", ":18855", "--db", dbPath)
	cmdServer.Dir = "../../"
	if err := cmdServer.Start(); err != nil {
		t.Fatalf("falha ao iniciar server: %v", err)
	}
	defer func() {
		cmdServer.Process.Kill()
	}()

	// Wait for server boot
	time.Sleep(3 * time.Second)

	// 3.5. Configure CLI & Seed Admin via CLI (testando Local SSO Server)
	t.Log("🌱 Configurando CLI para servidor local e Registrando Admin...")
	exec.Command(binPath, "config", "add", "local", "http://localhost:18844").Run()
	exec.Command(binPath, "config", "set-default", "local").Run()
	
	cmdReg := exec.Command(binPath, "auth", "register", "admin@crolab.com", "admin123")
	if err := cmdReg.Run(); err != nil {
		t.Logf("Aviso: Falha ao registrar admin (SaaS): %v", err)
	}

	// 4. Run Python Playwright Scrapes
	t.Log("📸 Acionando Scraper via Python Playwright...")
	scraperCmd := exec.Command("/tmp/crolab_screens/venv/bin/python", "screenshot.py", reportDir)
	outScrape, err := scraperCmd.CombinedOutput()
	if err != nil {
		t.Logf("Aviso: Falha ao rodar scraper (requer playwright instalado em /tmp/crolab_screens/venv). Output: %s", string(outScrape))
	} else {
		t.Logf("✅ Scraping finalizado: \n%s", string(outScrape))
	}

	// 5. Capture CLI logs
	t.Log("📝 Capturando outputs completos da CLI...")
	cliHelp, _ := exec.Command(binPath, "--help").CombinedOutput()
	cliAuth, _ := exec.Command(binPath, "auth", "--help").CombinedOutput()
	cliSubscribe, _ := exec.Command(binPath, "subscribe", "--help").CombinedOutput()
	cliConfig, _ := exec.Command(binPath, "config", "--help").CombinedOutput()
	cliRun, _ := exec.Command(binPath, "run", "--help").CombinedOutput()
	cliMachines, _ := exec.Command(binPath, "my-machines", "--help").CombinedOutput()
	cliLab, _ := exec.Command(binPath, "lab", "--help").CombinedOutput()
	cliMonitor, _ := exec.Command(binPath, "monitor", "--help").CombinedOutput()
	cliProv, _ := exec.Command(binPath, "provider", "--help").CombinedOutput()
	cliAdmin, _ := exec.Command(binPath, "admin", "--help").CombinedOutput()

	// 6. Compose Markdown
	mdContent := fmt.Sprintf(`# Relatório Forense CLI & Web Automatizado

Este relatório foi gerado algoritmicamente executando a suíte E2E nativa do Crolab.
O cliente Web agora conta com SSO sincronizado via Local Token "~/.crolab/config.json".

## 1. Módulos Core P2P (CLI)

### Principal
$$$%s$$$

### Autenticação & Planos
$$$%s$$$

$$$%s$$$

### Configuração
$$$%s$$$

### Operacionais & Jobs
$$$%s$$$

$$$%s$$$

$$$%s$$$

$$$%s$$$

### Cloud & SaaS Exec
$$$%s$$$

$$$%s$$$

## 2. Testes de Renderização
As imagens renderizadas capturaram o funcionamento real do código fonte Single-Binary embarcado:

### Otimizador Headless (SSO Session Sync)
- **Login Cliente:** ![Client Login](client_login.png)
- **Dashboard Cliente:** ![Client Dashboard](client.png)
- **Planos do Cliente:** ![Client Plans](client_plans.png)
- **Máquinas Conectadas:** ![Client Machines](client_machines.png)
- **Painel Admin:** ![Admin Dashboard](admin.png)
`, 
	string(cliHelp), string(cliAuth), string(cliSubscribe), string(cliConfig), 
	string(cliRun), string(cliMachines), string(cliLab), string(cliMonitor), 
	string(cliProv), string(cliAdmin))

	finalStr := strings.ReplaceAll(mdContent, "$$$", "```text")
	finalStr = strings.ReplaceAll(finalStr, "```text```text", "```")
	
	err = os.WriteFile(filepath.Join(reportDir, "relatorio_telas_comandos.md"), []byte(finalStr), 0644)
	if err != nil {
		t.Fatalf("Falha logando md: %v", err)
	}
	
	t.Logf("✅ Relatório de auditoria e Screenshots compilados com Sucesso em %s", reportDir)
}
